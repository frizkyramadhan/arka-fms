# ARKA MMS - Environment example
# Copy to .env and fill values

# Database (MySQL via Laragon)
DATABASE_URL="mysql://root:@localhost:3306/arka_mms"

# Auth (JWT + cookie untuk middleware RBAC & Remember Me)
# JWT_SECRET: rahasia server-only (API + middleware). Jika tidak set, pakai NEXT_PUBLIC_JWT_SECRET.
# JWT_SECRET="your-secret"
# Remember Me = true: masa berlaku token (contoh: 7d, 24h)
# NEXT_PUBLIC_JWT_EXPIRATION="7d"
# Remember Me = false: session (contoh: 8h)
# NEXT_PUBLIC_JWT_EXPIRATION_SESSION="8h"
# Cookie Max-Age saat Remember Me = true (hari). Kosong = 7 hari.
# JWT_COOKIE_MAX_AGE_DAYS=7
# Cookie accessToken pakai flag Secure hanya di HTTPS. next start (production) default Secure=true;
# di Docker/HTTP set false agar tidak redirect loop login (middleware tidak dapat cookie).
# JWT_COOKIE_SECURE=false
# NEXT_PUBLIC_JWT_SECRET="your-public-secret"

# MinIO (S3 compatible - for attachments)
# MINIO_ENDPOINT="localhost:9000"
# MINIO_ACCESS_KEY="minioadmin"
# MINIO_SECRET_KEY="minioadmin"
# MINIO_BUCKET="arka-mms"

# App
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Projects API (for User project scope dropdown). Proxy uses this; default in code: http://192.168.32.146:8080/api/projects
# PROJECTS_API_URL="http://192.168.32.146:8080/api/projects"
# Optional: call external URL directly from browser (must allow CORS). If unset, frontend uses /api/projects proxy.
# NEXT_PUBLIC_PROJECTS_API_URL="/api/projects"

# ARK Fleet API (for Unit sync). Server-side only.
# ARK_FLEET_EQUIPMENTS_URL="http://192.168.32.15/ark-fleet/api/equipments"
