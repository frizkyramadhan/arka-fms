# ARKA MMS - Environment example
# Copy to .env and fill values

# Database (MySQL via Laragon)
DATABASE_URL="mysql://root:@localhost:3306/arka_mms"

# App
# APP_URL="http://localhost:3000"
# NEXT_PUBLIC_APP_URL="http://localhost:3000"

# -----------------------------------------------------------------------------
# Auth
# -----------------------------------------------------------------------------
# JWT_SECRET — server-only, wajib untuk sign/verify JWT (API + middleware).
#             Jangan pakai NEXT_PUBLIC_ untuk secret utama.
# JWT_SECRET="generate-long-random-string"

# Expiration (boleh NEXT_PUBLIC — bukan secret)
# NEXT_PUBLIC_JWT_EXPIRATION="7d"
# NEXT_PUBLIC_JWT_EXPIRATION_SESSION="8h"

# Cookie middleware (optional)
# JWT_COOKIE_MAX_AGE_DAYS=7
# JWT_COOKIE_SECURE=false   # true/default di HTTPS; false di Docker HTTP

# Legacy/demo — src/@fake-db/auth/jwt.js saja. Jangan samakan dengan JWT_SECRET.
# NEXT_PUBLIC_JWT_SECRET="demo-only-different-from-jwt-secret"
# NEXT_PUBLIC_JWT_REFRESH_TOKEN_SECRET="demo-only"

# MinIO (S3 compatible - for attachments)
# MINIO_ENDPOINT="localhost:9000"
# MINIO_ACCESS_KEY="minioadmin"
# MINIO_SECRET_KEY="minioadmin"
# MINIO_BUCKET="arka-mms"

# Projects API (for User project scope dropdown). Proxy uses this.
# PROJECTS_API_URL="http://host/api/projects"
# NEXT_PUBLIC_PROJECTS_API_URL="/api/projects"

# ARK Fleet API (for Unit sync). Server-side only.
# ARK_FLEET_EQUIPMENTS_URL="http://host/ark-fleet/api/equipments"
