# Database (MySQL - Laragon)
DATABASE_URL="mysql://root:@localhost:3306/arka_mms"

# Auth (JWT + cookie untuk middleware RBAC & Remember Me)
# JWT_SECRET: rahasia server-only (API + middleware). Jika tidak set, pakai NEXT_PUBLIC_JWT_SECRET.
JWT_SECRET="dd5f3089-40c3-403d-af14-d0c228b05cb4"
# Remember Me = true: masa berlaku token & cookie
NEXT_PUBLIC_JWT_EXPIRATION="7d"
# Remember Me = false: session (token & cookie habis setelah ini)
NEXT_PUBLIC_JWT_EXPIRATION_SESSION="8h"
# Cookie Max-Age (detik) saat Remember Me = true. Kosong = pakai 7 hari.
# JWT_COOKIE_MAX_AGE_DAYS=7
NEXT_PUBLIC_JWT_SECRET="dd5f3089-40c3-403d-af14-d0c228b05cb4"
NEXT_PUBLIC_JWT_REFRESH_TOKEN_SECRET="7c4c1c50-3230-45bf-9eae-c9b2e401c767"

# Projects API (for User project scope dropdown). Proxy uses this; used by users and units.
PROJECTS_API_URL="http://192.168.32.15/ark-fleet/api/projects"

# ARK Fleet API (for Unit sync). Server-side only.
ARK_FLEET_EQUIPMENTS_URL="http://192.168.32.15/ark-fleet/api/equipments"
